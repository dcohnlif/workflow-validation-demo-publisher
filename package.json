{
  "name": "@redhat/workflow-validation-demo-publisher",
  "version": "0.1.0",
  "description": "CLI tool that transforms workflow validation artifacts into interactive Arcade demos",
  "type": "module",
  "bin": {
    "demo-publisher": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "check": "npm run typecheck && npm run lint && npm test"
  },
  "dependencies": {
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.39.0",
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "eslint": "^9.39.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^16.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.ts": ["eslint --fix"]
  },
  "license": "Apache-2.0"
}
